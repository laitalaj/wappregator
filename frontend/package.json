{
  "name": "wappregator-frontend",
  "version": "0.1.0",
  "description": "An aggregator for Wappuradios",
  "type": "module",
  "scripts": {
    "start": "vite",
    "watch:deps": "chokidar 'package.json' 'pnpm-lock.yaml' --initial -c 'pnpm i'",
    "dev": "vite",
    "dev:container": "pnpm i && concurrently -k -n 'dev,watch:deps' -c 'blue,green' 'pnpm dev --host' 'pnpm watch:deps'",
    "build": "vite build",
    "serve": "vite preview",
    "lint": "oxfmt src && oxlint src && eslint"
  },
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/parser": "^8.54.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-solid": "^0.14.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10"
  },
  "dependencies": {
    "@solid-primitives/scheduled": "^1.5.3",
    "@solidjs/router": "^0.16.1",
    "@tabler/icons-solidjs": "^3.36.1",
    "@thisbeyond/solid-select": "^0.16.0",
    "date-fns": "^4.1.0",
    "flexsearch": "^0.8.212",
    "hls.js": "^1.6.15",
    "socket.io-client": "^4.8.3",
    "solid-js": "^1.9.11"
  },
  "packageManager": "pnpm@10.29.1+sha512.48dae233635a645768a3028d19545cacc1688639eeb1f3734e42d6d6b971afbf22aa1ac9af52a173d9c3a20c15857cfa400f19994d79a2f626fcc73fccda9bbc"
}